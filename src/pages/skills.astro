---
// Este es el "Router" de Astro
import Layout from "../layouts/Layout.astro";
import { Skills as SkillsComponents } from "../components/Skills"; // Tu componente TSX real
import { DEFAULT_LANG } from "../locales";

// Forzamos el idioma por defecto
const currentLang = DEFAULT_LANG;
---

<Layout title="Habilidades | Portafolio">
  <section class="py-30 px-4">
    <div class="container mx-auto max-w-6xl">
      <div class="mb-8">
        <!-- Astro inyecta el TSX aquí -->
        <SkillsComponents lang={currentLang} client:load />
      </div>
    </div>
  </section>
</Layout>
