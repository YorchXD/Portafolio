---
// Importamos el CSS global para que Tailwind funcione en todo el sitio
// import '@fontsource-variable/inter';
import "../styles/global.css";
import { Navbar } from "../components/Navbar";
import { DEFAULT_LANG } from "../locales";

interface Props {
  title: string;
}

const { title } = Astro.props;

const pathname = new URL(Astro.request.url).pathname;

// Forzamos el idioma por defecto
const currentLang = DEFAULT_LANG;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Ingeniero Civil en Computación especializado en React, .NET y desarrollo Full Stack. Portafolio con proyectos, experiencia y contacto."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="apple-touch-icon" sizes="57x57" href="/images/favicons/apple-icon-57x57.png" />
    <link rel="apple-touch-icon" sizes="60x60" href="/images/favicons/apple-icon-60x60.png" />
    <link rel="apple-touch-icon" sizes="72x72" href="/images/favicons/apple-icon-72x72.png" />
    <link rel="apple-touch-icon" sizes="76x76" href="/images/favicons/apple-icon-76x76.png" />
    <link
      rel="apple-touch-icon"
      sizes="114x114"
      href="/images/favicons/apple-icon-114x114.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="120x120"
      href="/images/favicons/apple-icon-120x120.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="144x144"
      href="/images/favicons/apple-icon-144x144.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="152x152"
      href="/images/favicons/apple-icon-152x152.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/images/favicons/apple-icon-180x180.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href="/images/favicons/android-icon-192x192.png"
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/images/favicons/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicons/favicon-16x16.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="msapplication-TileColor" content="#ffffff" />
    <meta name="msapplication-TileImage" content="/ms-icon-144x144.png" />
    <meta name="theme-color" content="#ffffff" />
    <title>{title}</title>

    <!-- Open Graph (cuando compartes en WhatsApp, LinkedIn, etc.) -->
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Portafolio de Ingeniero Full Stack especializado en React y .NET"
    />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/logo-Yorch.png" />
    <!-- <meta property="og:url" content="https://tu-dominio.com" /> -->

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta
      name="twitter:description"
      content="Portafolio de Ingeniero Full Stack"
    />
    <meta name="twitter:image" content="/images/logo-Yorch.png" />
  </head>
  <body class="">
    <div class="fixed inset-0 -z-10 overflow-hidden bg-gray-100">
      <div
        class="absolute top-[-15%] left-[-10%] w-[70%] h-[70%] rounded-full bg-green-600 opacity-90 blur-[90px] animate-[pulse_7s_infinite]"
      >
      </div>

      <div
        class="absolute bottom-[-15%] right-[-10%] w-[80%] h-[80%] rounded-full bg-amber-400 opacity-90 blur-[100px] animate-[pulse_9s_infinite]"
      >
      </div>

      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[110%] h-[110%] rounded-full bg-white opacity-100 blur-[130px]"
      >
      </div>
    </div>

    <!-- El slot es donde se inyectará tu página (index.astro) -->
    <Navbar currentPath={pathname} lang={currentLang} client:load />
    <slot />
  </body>
</html>

<style is:global>
  /* Forzamos que el scroll sea suave al navegar por el portafolio */
  html {
    scroll-behavior: smooth;
  }
</style>
